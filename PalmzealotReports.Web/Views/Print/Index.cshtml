@model PalmzealotReports.Web.Models.FormPrintViewModel

@{
    Layout = null;
    ViewData["Title"] = "Print Form";
}
<!doctype html>

<html lang="en">
    <head>
        <meta charset="utf-8" />
        <title>@Model.Filename</title>

        <style type="text/css">
            :root {
                --border: 1px solid black;
            }

            body {
                font-family: Arial, Helvetica, sans-serif;
                font-size: 7.5pt;
            }

            table {
                border-collapse: collapse;
                width: 100%;
            }

            td:not(.header),
            th {
                border-top: var(--border);
                border-bottom: var(--border);
                padding: 3pt;
            }

            td:first-of-type:not(.header),
            th:first-of-type {
                border-left: var(--border);
            }

            td:last-of-type:not(.header),
            th:last-of-type {
                border-right: var(--border);
            }

            .header {
                text-align: center;
            }

            th {
                background: #4285f4;
                color: #fff;
                text-align: left;
            }

            .checkbox {
                padding-left: 5pt;
                padding-right: 5pt;
                text-align: center;
            }

            .bold {
                font-weight: bold;
            }

            .rightline {
                border-right: var(--border);
            }
        </style>
    </head>

    <body>
        <table cellspacing="0">
            <thead>
                <tr>
                    <td class="header" colspan="@Model.Columns.Length">
                        @Html.Raw(Model.Header)
                    </td>
                </tr>
                <tr>
                    @for (int i = 0; i < Model.Columns.Length; i++)
                    {
                        <th class="@Model.Classes[i]">@Model.Columns[i]</th>
                    }
                </tr>
            </thead>
            <tbody>
                @foreach (string[] row in Model.Rows)
                {
                    <tr>
                        @for (int i = 0; i < row.Length; i++)
                        {
                            <td class="@Model.Classes[i]">@row[i]</td>
                        }
                    </tr>
                }
            </tbody>
        </table>

        <script>
            window.print();
        </script>
    </body>
</html>